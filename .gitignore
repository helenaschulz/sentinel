# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
src/*.egg-info/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── Data — download from Kaggle competition page ──────────────────────────────
# https://www.kaggle.com/competitions/esa-adb-challenge/data
# Place files in data/raw/ after downloading.
data/raw/*.parquet

# ── Processed arrays — regenerated by running notebooks 01–02 ─────────────────
data/processed/

# ── Tool / test caches ────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Results (score files) ─────────────────────────────────────────────────────
results/
!results/scores/.gitkeep

# ── Saved models ─────────────────────────────────────────────────────────────
models/*.pkl
models/*.json
!models/.gitkeep

# ── Submissions — generated by running notebooks 03–04 ────────────────────────
submissions/*.parquet
